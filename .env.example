VITE_SUPABASE_ANON_KEY=ta-cle-anon-ici

# Edge Function send-rappel-rdv
# A definir dans Supabase Dashboard > Edge Functions > Secrets
SUPABASE_URL=https://ton-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ta-cle-service-role-ici

# SMS Twilio
SMS_PROVIDER=twilio
SMS_SIMULATION=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=ton-auth-token-twilio
TWILIO_FROM_NUMBER=+15551234567
# Alternative a TWILIO_FROM_NUMBER si tu utilises un Messaging Service :
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS Africa's Talking, seulement si SMS_PROVIDER=africastalking
SMS_USERNAME=sandbox
SMS_API_KEY=ta-cle-sms-ici
SMS_SENDER_ID=SMILE
